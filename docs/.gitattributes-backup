# Default - normalize text files line endings
* text=auto

# Scripts and programming languages - enforce LF
*.sh text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.java text eol=lf
*.rb text eol=lf
*.php text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.htm text eol=lf

# Documentation - enforce LF
*.md text eol=lf
*.rst text eol=lf
*.adoc text eol=lf

# Configuration - normalize to LF
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.env text eol=lf
*.conf text eol=lf
*.cfg text eol=lf
.editorconfig text eol=lf

# Batch files - enforce CRLF for Windows
*.bat text eol=crlf

# Treat binary files as-is
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.pdf binary
*.psd binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.bz2 binary
*.iso binary
*.7z binary
*.rar binary

# Enable UTF-8 normalizations for filenames
* text=auto

# Custom diff rules for complex formats
*.json diff=json
*.xml diff=xml
*.scss diff=css
*.svg -text

# Disable diff for large non-diffable files
*.log -diff
*.csv -diff